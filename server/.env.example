# Copy this file to .env and fill in your values

PORT=3000

# Admin panel password
ADMIN_PASSWORD=admin123

# JWT signing secret — change this to a long random string in production
JWT_SECRET=jcd-change-this-secret-key

# Paystack secret key — get it from https://dashboard.paystack.com/#/settings/developers
# Leave blank to disable card payments (Cash on Delivery will still work)
PAYSTACK_SECRET_KEY=

# URL the site is served from (used for Paystack callback)
FRONTEND_URL=http://localhost:3000
